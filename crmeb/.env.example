APP_DEBUG=false

[APP]
DEFAULT_TIMEZONE=Asia/Shanghai

[DATABASE]
TYPE=mysql
HOSTNAME=127.0.0.1
HOSTPORT=3306
USERNAME=your_database_user
PASSWORD=change_me
DATABASE=your_database_name
PREFIX=eb_
CHARSET=utf8
DEBUG=false

[LANG]
default_lang=zh-cn

[CACHE]
DRIVER=file
CACHE_PREFIX=crmeb_dev:
CACHE_TAG_PREFIX=crmeb_tag_dev:

[REDIS]
REDIS_HOSTNAME=127.0.0.1
PORT=6379
REDIS_PASSWORD=
SELECT=0

[QUEUE]
QUEUE_NAME=dev
